# App
HEADLESS=true

# Land Registry Credentials
LAND_REGISTRY_USERNAME=
LAND_REGISTRY_PASSWORD=

# IDU / Tracesmart Credentials
# The scraper reads these to log in automatically — no human needed.
IDU_USERNAME=
IDU_PASSWORD=

# OTP Email (IMAP) — used to auto-read the One-Time Password from your inbox
# The OTP email must be the address registered on the Tracesmart account.
# Gmail: Host=imap.gmail.com, Port=993 — use an App Password, not your real password
#        Go to: myaccount.google.com → Security → App passwords
# Outlook/Hotmail: Host=imap-mail.outlook.com, Port=993
OTP_EMAIL_HOST=imap.gmail.com
OTP_EMAIL_PORT=993
OTP_EMAIL_USE_SSL=true
OTP_EMAIL_USER=
OTP_EMAIL_PASS=

# How often (hours) the background session keeper proactively refreshes the
# session before it expires. Default: 4 hours. Tracesmart sessions last ~8 h.
IDU_SESSION_REFRESH_HOURS=4

# AWS S3 Screenshot Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=scraper-api-assets-2026
